# Channel Access Token แบบ long-lived จาก LINE Developers Console (Messaging API)
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-channel-access-token

# secret สำหรับป้องกัน MCP endpoint (แนะนำให้ตั้งเสมอ) จะถูกฝังไว้ใน path ของ URL
# ตัวอย่าง URL ที่ได้: https://your-app.onrender.com/mcp/<MCP_SECRET>
MCP_SECRET=change-me-to-a-random-string

# port สำหรับรันในเครื่อง (ตอน deploy บน Render จะกำหนดให้อัตโนมัติ ไม่ต้องตั้งเอง)
PORT=3000
